# ==========================================
# REQUIRED CONFIGURATION
# ==========================================

# 1. Database (Neon Postgres)
# Use the *pooled* connection string from the Neon console.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# 2. OpenAI API Key (Required for Phase 1 ingestion & Cloud LLM pipeline)
OPENAI_API_KEY=your_openai_api_key_here

# 3. Cloudinary (Required for media uploads - audio, video, images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==========================================
# V2 PIPELINE CONFIGURATION
# ==========================================

# Set to True to use OpenAI (gpt-4o-mini) for the advanced V2 agents instead of local LLMs.
USE_CLOUD_LLM=True

# If USE_CLOUD_LLM=False, you MUST provide at least one local LLM endpoint (e.g., via ngrok pointing to Ollama)
LOCAL_LLM_BASE_URL=https://xxxx.ngrok-free.app
LOCAL_LLM_GATE_URL=https://gate-url.ngrok-free.app
LOCAL_LLM_REWRITER_URL=https://rewriter-url.ngrok-free.app
LOCAL_LLM_DECISION_URL=https://decision-url.ngrok-free.app

# ==========================================
# OPTIONAL OVERRIDES (These track the app's default values)
# You only need to change these if you want to override the default behavior.
# ==========================================

# Application Environment
ENVIRONMENT=development
DEBUG=false

# Redis / Celery (Defaults to local Docker compose)
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# Qdrant Vector Store (Defaults to local Docker compose)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Local LLM Models (Only used if USE_CLOUD_LLM=False)
LOCAL_LLM_REWRITER_MODEL=Qwen/Qwen3.5-2B
LOCAL_LLM_GATE_MODEL=Qwen/Qwen3.5-2B
LOCAL_LLM_DECISION_MODEL=qwen3.5:4b

# Rate Limiting (Protects quotas by limiting requests per IP)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_EXPENSIVE_REQUESTS=10
RATE_LIMIT_EXPENSIVE_WINDOW_SECONDS=60
RATE_LIMIT_GENERAL_REQUESTS=120
RATE_LIMIT_GENERAL_WINDOW_SECONDS=60
RATE_LIMIT_GLOBAL_REQUESTS=300
RATE_LIMIT_GLOBAL_WINDOW_SECONDS=60

# Ingestion Tuning (Chunk sizes, processing, Whisper/Vision models)
WHISPER_MODEL=whisper-1
VISION_MODEL=gpt-4o-mini
AUDIO_SEGMENT_MIN_SECONDS=15
AUDIO_SEGMENT_MAX_SECONDS=30
VIDEO_KEYFRAME_INTERVAL_SECONDS=5
VIDEO_MAX_KEYFRAMES=8
VIDEO_KEYFRAME_MAX_WIDTH=512
VISION_CALL_DELAY_SECONDS=2
MAX_UPLOAD_BYTES=10485760

# OpenAI API Retry Settings (Used during ingestion/generation)
OPENAI_MAX_RETRIES=8
OPENAI_RETRY_MIN_DELAY_SECONDS=2

# System Paths (For media processing)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# V1 Legacy Pipeline Models (If you hit the old /search endpoint)
ROUTER_MODEL=gpt-4o-mini
SYNTHESIS_MODEL=gpt-4o-mini
SEARCH_TOP_K=5
