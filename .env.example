# Application
ENVIRONMENT=development
DEBUG=false

# Neon Postgres (required) — use the *pooled* connection string from the Neon console.
# SQLAlchemy/psycopg driver prefix:
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# Redis / Celery (local Docker Compose)
REDIS_URL=redis://localhost:6379/0

# Qdrant (local Docker Compose)
QDRANT_URL=http://localhost:6333

# OpenAI (required from Phase 1 ingestion onward)
OPENAI_API_KEY=

# Optional ingestion tuning (M2–M4)
WHISPER_MODEL=whisper-1
AUDIO_SEGMENT_MIN_SECONDS=15
AUDIO_SEGMENT_MAX_SECONDS=30
VISION_MODEL=gpt-4o-mini
VIDEO_KEYFRAME_INTERVAL_SECONDS=5
VIDEO_MAX_KEYFRAMES=8
VIDEO_KEYFRAME_MAX_WIDTH=512
VISION_CALL_DELAY_SECONDS=2
OPENAI_MAX_RETRIES=8
OPENAI_RETRY_MIN_DELAY_SECONDS=2
MAX_UPLOAD_BYTES=10485760
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
ROUTER_MODEL=gpt-4o-mini
SYNTHESIS_MODEL=gpt-4o-mini
SEARCH_TOP_K=5

# Cloudinary (raw file uploads — text, audio, video)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=scrutinize

# Rate limiting (per client IP; protects OpenAI/Whisper quotas)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_EXPENSIVE_REQUESTS=10
RATE_LIMIT_EXPENSIVE_WINDOW_SECONDS=60
RATE_LIMIT_GENERAL_REQUESTS=120
RATE_LIMIT_GENERAL_WINDOW_SECONDS=60
RATE_LIMIT_GLOBAL_REQUESTS=300
RATE_LIMIT_GLOBAL_WINDOW_SECONDS=60

# Frontend
VITE_API_URL=http://localhost:8000

# v2 local LLM pipeline (Ollama via ngrok — rotate URL in env when tunnel changes)
LOCAL_LLM_BASE_URL=
LOCAL_LLM_REWRITER_MODEL=qwen3.5:2b
LOCAL_LLM_GATE_MODEL=qwen3.5:0.8b
LOCAL_LLM_DECISION_MODEL=qwen3.5:4b
LOCAL_LLM_TIMEOUT_S=120
V2_MAX_PIPELINE_ATTEMPTS=2
V2_CONFIDENCE_THRESHOLD=0.7
V2_RRF_K=60
V2_RRF_NUM_LISTS=2
V2_RRF_TOP_K=5
