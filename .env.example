# Application
ENVIRONMENT=development
DEBUG=false

# Neon Postgres (required) — use the *pooled* connection string from the Neon console.
# SQLAlchemy/psycopg driver prefix:
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# Redis / Celery (local Docker Compose)
REDIS_URL=redis://localhost:6379/0

# Qdrant (local Docker Compose)
QDRANT_URL=http://localhost:6333

# OpenAI (required from Phase 1 ingestion onward)
OPENAI_API_KEY=

# Cloudinary (raw file uploads — text, audio, video)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional prefix for uploaded assets (default: scrutinize)
CLOUDINARY_FOLDER=scrutinize

# Frontend
VITE_API_URL=http://localhost:8000
